# Configuration for the non-NixOS (Ubuntu/Debian) installer.
#
#   cp config.env.example config.env      # config.env is gitignored
#   $EDITOR config.env                    # set GATEWAY (or CONNECTIONS)
#   sudo ./install.sh
#
# Provide EITHER a single GATEWAY (+ optional VPN_NAME), OR a CONNECTIONS list
# for multiple named connections. Everything else has a sensible default.
# You can also pass values via the environment instead of a file, e.g.:
#   sudo GATEWAY=https://vpn.example.com/saml ./install.sh

# --- Connections (choose ONE style) ---------------------------------------

# Single connection. Full VPN gateway URL, exactly as your administrator gives
# it to you. May include a path (e.g. /saml). Scheme optional (https:// assumed).
#   example: https://vpn.example.com/saml
GATEWAY=""

# Name shown in the GNOME/KDE network menu and used with `nmcli connection up`.
# Keep to letters, digits, spaces, dot, dash, underscore.
VPN_NAME="Pulse VPN"

# Multiple connections. If set, this takes precedence over GATEWAY/VPN_NAME.
# One "Name = URL" per line (or separate entries with ';'). Each name follows
# the same charset rule as VPN_NAME and must be unique. Gateways may share a
# host (as below) or point at different hosts — the installer sets up the
# local cert SANs and /etc/hosts entries for every host it sees.
#
# CONNECTIONS="
#   Pulse emp        = https://pcs.flxvpn.net/emp
#   Pulse emp-split  = https://pcs.flxvpn.net/emp-split
# "
CONNECTIONS=""

# --- Optional -------------------------------------------------------------

# Local port the MITM auth proxy listens on (loopback only). Port 443 is
# NAT-redirected here during authentication. Change only if 8443 is taken.
PROXY_PORT="8443"

# DTLS/ESP (UDP) for better throughput. "true" recommended; "false" = TCP-only.
ENABLE_DTLS="true"

# Tunnel MTU passed to openconnect (--mtu) and enforced as a ceiling by the
# helper. 1300 is a universal safe value. Empty ("") uses the server MTU.
VPN_MTU="1300"

# Install the auto-reconnect layer (systemd sleep hook, NM dispatcher, vpnc
# hooks, rp_filter=loose). "true" recommended for laptops that suspend/roam.
# With multiple connections, whichever was active is what gets reconnected.
ENABLE_RECOVERY="true"
